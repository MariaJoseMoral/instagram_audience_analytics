            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='[Calculation_1714939138793473]' function='order' user:ui-marker='order'>
                <groupfilter function='level-members' level='[none:media_id:ok]' user:ui-enumeration='all' user:ui-marker='enumerate' />
              </groupfilter>
            </groupfilter>
          </filter>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.04nfda31nb982r18u0gdu0k62vbs].[none:caption:nk]' direction='ASC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.04nfda31nb982r18u0gdu0k62vbs].[sum:total_interactions:qk]' shelf='rows' />
